# ChancePing .dockerignore - 构建上下文优化
# 减少构建上下文体积，加速镜像构建

# 依赖（构建时重新安装）
node_modules/

# 构建输出
dist/
build/

# 环境变量（含真实 API Key，禁止进入镜像）
.env
.env.local
.env.*.local
# 保留 .env.example 作为模板

# 运行时数据（由 volume 挂载）
data/
reports/
exports/
meili-data/

# Git
.git/
.gitignore
.gitattributes

# 文档与回报（运行时不需要）
docs/
*.md
!README.md
!LICENSE
!TRADEMARKS.md
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!SECURITY.md
!ROADMAP.md

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# 测试与日志
coverage/
.nyc_output/
*.log
e2e-real-search-log*.txt

# Docker 自身（避免递归构建）
Dockerfile
docker-compose.yml
.dockerignore

# TRAE IDE 元数据
.trae/
