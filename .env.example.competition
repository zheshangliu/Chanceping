# ===========================================
# 盯一下 ChancePing - 参赛版环境变量模板
# 策略：只用 Qwen Cloud API，部署在阿里云
# 预算：$40 voucher
# 截止：2026-07-09
# ===========================================

# LLM 策略选择
LLM_STRATEGY=competition

# Qwen (DashScope) API Key - 唯一 LLM provider
# 获取地址：https://dashscope.console.aliyun.com
# 参赛版仅需要此 key
DASHSCOPE_API_KEY=

# Serper API Key - 搜索 provider（可选）
SERPER_API_KEY=

# Jina Reader API Key - 网页内容抓取（可选）
JINA_READER_API_KEY=

# 阿里云部署配置（参赛版独有）
# 部署目标：Alibaba Cloud Function Compute / ECS
# 区域：cn-hangzhou（推荐，与 DashScope 同区域降低延迟）
ALIYUN_REGION=cn-hangzhou
