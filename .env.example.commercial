# ===========================================
# 盯一下 ChancePing - 商业版环境变量模板
# 策略：追求成本最优，多 Provider 混合
# ===========================================

# LLM 策略选择（commercial / competition）
LLM_STRATEGY=commercial

# Z.AI (GLM) API Key - 批量初筛主力（免费）
# 获取地址：https://z.ai/model-api
ZAI_API_KEY=

# DeepSeek API Key - 核心判断 + 需求理解 + 初筛降级
# 获取地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Qwen (DashScope) API Key - 报告生成 + 兜底
# 获取地址：https://dashscope.console.aliyun.com
DASHSCOPE_API_KEY=

# Serper API Key - 搜索 provider（可选，V0.8 搜索层用）
SERPER_API_KEY=

# Jina Reader API Key - 网页内容抓取（可选）
JINA_READER_API_KEY=
