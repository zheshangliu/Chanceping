# ===========================================
# ChancePing 盯机会 - 环境变量模板
# ===========================================
# 所有 API Key 均为可选，未配置时自动使用 Mock 模式
# 复制此文件为 .env 并填入真实 Key：
#   cp .env.example .env        (Linux/Mac)
#   copy .env.example .env      (Windows)
# ===========================================

# --- 服务器配置 ---
# API 服务器端口（默认 3000）
PORT=3000

# --- LLM 策略 ---
# competition: 纯 Qwen（参赛合规，部署在阿里云）
# commercial: GLM 免费 + DeepSeek 性价比 + Qwen 报告（成本最优）
LLM_STRATEGY=competition

# --- LLM API Keys（可选，无 Key 走 Mock 模式） ---

# Qwen (DashScope) - 报告生成 + 兜底
# 获取地址：https://dashscope.console.aliyun.com
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=

# DeepSeek - 核心判断（商业版主力）
# 获取地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Z.AI (GLM) - 批量初筛（商业版免费层）
# 获取地址：https://z.ai/model-api
ZAI_API_KEY=

# --- 搜索 Provider API Keys（可选，无 Key 走 Mock 模式） ---

# Serper - 全网搜索
# 获取地址：https://serper.dev
SERPER_API_KEY=

# 博查 Bocha - 中文搜索
# 获取地址：https://open.bochaai.com
BOCHA_API_KEY=

# Exa - 语义搜索
# 获取地址：https://exa.ai
EXA_API_KEY=

# Google CSE - 站点限定搜索
# 获取地址：https://developers.google.com/custom-search
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# --- 内容抓取（可选，无 Key 走 Mock 模式） ---
# Jina Reader - 网页转纯文本
# 获取地址：https://jina.ai/reader
JINA_READER_API_KEY=

# --- 存储配置 ---
# local: 本地文件存储（默认，零依赖）
# meili: Meilisearch 全文搜索（需单独部署 Meilisearch 实例）
STORE_TYPE=local

# Meilisearch 配置（仅 STORE_TYPE=meili 时生效）
MEILI_HOST=
MEILI_API_KEY=
MEILI_MOCK=false

# --- 调度器配置 ---
# 参赛版默认关闭，手动触发搜索
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_MS=60000
SCHEDULER_TIMEZONE=Asia/Shanghai

# --- 推送通知 ---
# Mock 模式：true 时所有通知仅打印日志，不实际发送
NOTIFY_MOCK_MODE=true

# 企业微信机器人
WECHAT_WEBHOOK_URL=

# 通用 Webhook
WEBHOOK_URL=

# 邮件（SMTP）
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=

# --- 报告导出 ---
# PDF 导出开关（需安装 puppeteer：npm install puppeteer）
PDF_EXPORT_ENABLED=false
PUPPETEER_EXECUTABLE_PATH=

# --- 代理（可选，r.jina.ai 等海外服务需要） ---
# 中国大陆环境访问 r.jina.ai 需配置 Clash HTTP 代理
# NODE_USE_ENV_PROXY=1
# HTTP_PROXY=http://127.0.0.1:7897
# HTTPS_PROXY=http://127.0.0.1:7897
